# .env.example - このファイルをコピーして .env を作成し、実際の値を入力してください
# .env は絶対に Git にコミットしないこと

# X API（必須）
BEARER_TOKEN=your_bearer_token_here

# CoinGecko API（エンティティ自動更新用）
# Lite プランの API キーを設定
COINGECKO_API_KEY=your_coingecko_api_key_here

# Slack Webhook（任意）
# 設定しない場合はターミナルに通知が出力される
# 取得方法: Slack App → Incoming Webhooks → Webhook URL をコピー
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX
